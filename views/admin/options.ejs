<%-include('../partials/head.ejs', { title: title }) %>
<%- include('../partials/sidebar.ejs') %>

<main class="md:ml-64 pt-14 md:pt-0 pb-20 md:pb-8 min-h-screen">
  <div class="max-w-2xl mx-auto px-4 py-6 space-y-5">

    <!-- Header -->
    <div class="flex items-center gap-3">
      <a href="/admin/dashboard" class="w-9 h-9 bg-slate-800 border border-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors">←</a>
      <div>
        <h1 class="text-xl font-bold text-white">⚙️ Opsi Absensi</h1>
        <p class="text-sm text-slate-500">Kelola jenis status kehadiran</p>
      </div>
    </div>

    <!-- Flash -->
    <% if (success && success.length) { %>
      <div class="bg-green-500/10 border border-green-500/20 text-green-400 text-sm px-4 py-3 rounded-xl"><%= success[0] %></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl"><%= error[0] %></div>
    <% } %>

    <!-- Form Tambah -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5">
      <div class="text-sm font-semibold text-white mb-4">➕ Tambah Opsi Baru</div>
      <form action="/admin/options/add" method="POST" class="flex flex-col sm:flex-row gap-3" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="text" name="name" placeholder="Nama status (cth: Dinas Luar)" required
          class="flex-1 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl px-4 py-2.5 focus:outline-none focus:border-sky-500 placeholder-slate-600">
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-400">Warna:</label>
          <input type="color" name="color" value="#64748b"
            class="w-10 h-10 rounded-lg border border-slate-700 bg-slate-800 cursor-pointer p-1">
        </div>
        <button type="submit" class="bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors whitespace-nowrap">
          Tambah
        </button>
      </form>
    </div>

    <!-- Daftar Opsi -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-800">
        <div class="text-sm font-semibold text-white">Daftar Opsi Absensi</div>
      </div>
      <% if (!options || options.length === 0) { %>
        <div class="text-center text-slate-600 py-10">
          <div class="text-3xl mb-2">📭</div>
          <div class="text-sm">Belum ada opsi absensi</div>
        </div>
      <% } %>
      <% options.forEach((opt, i) => { %>
      <div class="flex items-center justify-between px-5 py-3.5 border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 rounded-full flex-shrink-0" style="background: <%= opt.color %>"></div>
          <span class="text-sm font-medium" style="color: <%= opt.color %>"><%= opt.name %></span>
        </div>
        <div class="flex items-center gap-2">
          <button type="button"
            data-action="/admin/options/edit/<%= opt.id %>"
            data-name="<%= opt.name %>"
            data-color="<%= opt.color %>"
            onclick="openEditModal(this)"
            class="text-xs bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 px-3 py-1 rounded-lg hover:bg-yellow-500/20 transition-colors">
            ✏️ Edit
          </button>
          <button type="button"
            data-action="/admin/options/delete/<%= opt.id %>"
            data-name="<%= opt.name %>"
            data-color="<%= opt.color %>"
            onclick="openDeleteModal(this)"
            class="text-xs bg-red-500/10 text-red-400 border border-red-500/20 px-3 py-1 rounded-lg hover:bg-red-500/20 transition-colors">
            🗑 Hapus
          </button>
        </div>
      </div>
      <% }) %>
      <div class="px-5 py-3 text-xs text-slate-600">Total: <%= options.length %> opsi</div>
    </div>

  </div>

  <!-- Modal Konfirmasi Hapus -->
  <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-slate-900 border border-slate-700/50 rounded-2xl p-8 w-full max-w-sm mx-4 flex flex-col items-center gap-4 text-center">
      <div class="w-16 h-16 bg-red-500/20 rounded-2xl flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/>
        </svg>
      </div>
      <div>
        <h2 class="text-white font-bold text-lg mb-1">Konfirmasi Hapus</h2>
        <p class="text-slate-400 text-sm leading-relaxed">Opsi status kehadiran ini akan dihapus secara permanen.</p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 w-full flex items-center gap-3">
        <div id="deleteColorDot" class="w-4 h-4 rounded-full flex-shrink-0"></div>
        <div class="text-left">
          <p class="text-slate-500 text-xs">Hapus opsi</p>
          <p id="deleteName" class="font-medium text-sm"></p>
        </div>
      </div>
      <div class="flex gap-3 w-full mt-1">
        <button onclick="closeDeleteModal()"
          class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 text-slate-300 py-2.5 rounded-xl text-sm transition-colors">
          ✕ Batal
        </button>
        <form id="deleteForm" method="POST" class="flex-1">
          <input type="hidden" name="_csrf" id="deleteCsrf" value="" />
          <button type="submit"
            class="w-full bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-xl text-sm font-semibold transition-colors">
            🗑 Hapus
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Modal Edit Opsi -->
  <div id="editModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-slate-900 border border-slate-700/50 rounded-2xl p-8 w-full max-w-sm mx-4 flex flex-col items-center gap-4 text-center">
      <div class="w-16 h-16 bg-yellow-500/20 rounded-2xl flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 3.487a2.25 2.25 0 1 1 3.182 3.182L7.5 19.213l-4 1 1-4 12.362-12.726z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-white font-bold text-lg mb-1">Edit Opsi Absensi</h2>
        <p class="text-slate-400 text-sm leading-relaxed">Ubah nama atau warna status kehadiran.</p>
      </div>
      <form id="editForm" method="POST" class="w-full flex flex-col gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="text-left">
          <label class="text-xs text-slate-400 mb-1 block">Nama Status</label>
          <input type="text" id="editName" name="name" required
            class="w-full bg-slate-800 border border-slate-700 text-white text-sm rounded-xl px-4 py-2.5 focus:outline-none focus:border-yellow-500 placeholder-slate-600">
        </div>
        <div class="text-left">
          <label class="text-xs text-slate-400 mb-1 block">Warna</label>
          <div class="flex items-center gap-3 bg-slate-800 border border-slate-700 rounded-xl px-4 py-2">
            <input type="color" id="editColor" name="color"
              class="w-8 h-8 rounded-lg border-0 bg-transparent cursor-pointer p-0">
            <span id="editColorLabel" class="text-sm text-slate-400 font-mono"></span>
          </div>
        </div>
        <div class="flex gap-3 mt-1">
          <button type="button" onclick="closeEditModal()"
            class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 text-slate-300 py-2.5 rounded-xl text-sm transition-colors">
            ✕ Batal
          </button>
          <button type="submit"
            class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-white py-2.5 rounded-xl text-sm font-semibold transition-colors">
            💾 Simpan
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Alert Validasi -->
  <div id="alertModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-slate-900 border border-slate-700/50 rounded-2xl p-8 w-full max-w-sm mx-4 flex flex-col items-center gap-4 text-center">
      <div class="w-16 h-16 bg-yellow-500/20 rounded-2xl flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-white font-bold text-lg mb-1">Nama Status Belum Diisi Woilah </h2>
        <p class="text-slate-400 text-sm leading-relaxed">Ketik nama status kehadiran terlebih dahulu sebelum menekan tombol Tambah.</p>
      </div>
      <button onclick="closeAlertModal()"
        class="w-full bg-sky-500 hover:bg-sky-600 text-white py-2.5 rounded-xl text-sm font-semibold transition-colors">
        ✅ Oke, Mengerti
      </button>
    </div>
  </div>

  <script>
    // ---- Delete Modal ----
    function openDeleteModal(button) {
      const action = button.dataset.action;
      const name = button.dataset.name || '';
      const color = button.dataset.color || '#64748b';

      document.getElementById('deleteForm').action = action;
      document.getElementById('deleteCsrf').value = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
      document.getElementById('deleteName').textContent = name;
      document.getElementById('deleteName').style.color = color;
      document.getElementById('deleteColorDot').style.background = color;
      const modal = document.getElementById('deleteModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    function closeDeleteModal() {
      const modal = document.getElementById('deleteModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
    document.getElementById('deleteModal').addEventListener('click', function(e) {
      if (e.target === this) closeDeleteModal();
    });

    // ---- Edit Modal ----
    function openEditModal(button) {
      const action = button.dataset.action;
      const name = button.dataset.name || '';
      const color = button.dataset.color || '#64748b';

      document.getElementById('editForm').action = action;
      document.getElementById('editName').value = name;
      document.getElementById('editColor').value = color;
      document.getElementById('editColorLabel').textContent = color;
      const modal = document.getElementById('editModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    function closeEditModal() {
      const modal = document.getElementById('editModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
    document.getElementById('editModal').addEventListener('click', function(e) {
      if (e.target === this) closeEditModal();
    });
    document.getElementById('editColor').addEventListener('input', function() {
      document.getElementById('editColorLabel').textContent = this.value;
    });

    // ---- Alert Modal ----
    function closeAlertModal() {
      const modal = document.getElementById('alertModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
    document.getElementById('alertModal').addEventListener('click', function(e) {
      if (e.target === this) closeAlertModal();
    });
    document.querySelector('form[action="/admin/options/add"]').addEventListener('submit', function(e) {
      const nameInput = this.querySelector('input[name="name"]');
      if (!nameInput.value.trim()) {
        e.preventDefault();
        document.getElementById('alertModal').classList.remove('hidden');
        document.getElementById('alertModal').classList.add('flex');
        nameInput.focus();
      }
    });
  </script>
</main>

<%-include('../partials/bottomnav.ejs') %>
<%- include('../partials/footer.ejs') %>
