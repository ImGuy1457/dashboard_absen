<%-include('../partials/head.ejs', { title: title }) %>
<%- include('../partials/sidebar.ejs') %>

<main class="md:ml-64 pt-14 md:pt-0 pb-20 md:pb-8 min-h-screen">
  <div class="max-w-4xl mx-auto px-4 py-6 space-y-5">

    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-white">👥 Manajemen Akun Karyawan & Admin</h1>
        <p class="text-xs text-slate-500 mt-1">Daftar pengguna login integrasi absensi</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/admin/users/add" class="bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold px-4 py-2 rounded-xl transition-colors">
          + Tambah Karyawan / Admin
        </a>
      </div>
    </div>

    <!-- Flash -->
    <% if (success && success.length) { %>
      <div class="bg-green-500/10 border border-green-500/20 text-green-400 text-sm px-4 py-3 rounded-xl"><%= success[0] %></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl"><%= error[0] %></div>
    <% } %>

    <!-- Tabel -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800 text-slate-500 text-xs">
              <th class="text-left px-4 py-3">#</th>
              <th class="text-left px-4 py-3">Nama</th>
              <th class="text-left px-4 py-3">Jabatan</th>
              <th class="text-left px-4 py-3">Password</th>
              <th class="text-left px-4 py-3">Role Sistem</th>
              <th class="text-center px-4 py-3">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((u, i) => { %>
            <tr class="border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors">
              <td class="px-4 py-3 text-slate-500"><%= i + 1 %></td>
              <td class="px-4 py-3 text-white font-medium"><%= u.username %></td>
              <td class="px-4 py-3 text-slate-400"><%= u.jabatan || 'Belum Diatur' %></td>
              <td class="px-4 py-3 text-slate-500 font-mono text-xs">
                <%= u.password.startsWith('$2') ? '•••••••• (Encrypted)' : u.password %>
              </td>
              <td class="px-4 py-3">
                <span class="text-xs px-2.5 py-0.5 rounded-full font-medium 
                  <%= u.role === 'superadmin' ? 'bg-amber-500/20 text-amber-400' : u.role === 'admin' ? 'bg-purple-500/20 text-purple-400' : 'bg-sky-500/20 text-sky-400' %>">
                  <%= u.role %>
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-2">
                  <a href="/admin/users/edit/<%= u.id %>" class="text-xs bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 px-3 py-1 rounded-lg hover:bg-yellow-500/20 transition-colors">Edit</a>
                  <button type="button"
                    data-action="/admin/users/delete/<%= u.id %>"
                    data-name="<%= u.username %>"
                    onclick="openDeleteModal(this)"
                    class="text-xs bg-red-500/10 text-red-400 border border-red-500/20 px-3 py-1 rounded-lg hover:bg-red-500/20 transition-colors">
                    Hapus
                  </button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="px-4 py-3 text-xs text-slate-600">Total: <%= users.length %> akun terdaftar</div>
    </div>

  </div>

  <!-- Modal Konfirmasi Hapus -->
  <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-slate-900 border border-slate-700/50 rounded-2xl p-8 w-full max-w-sm mx-4 flex flex-col items-center gap-4 text-center">
      
      <!-- Icon -->
      <div class="w-16 h-16 bg-red-500/20 rounded-2xl flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/>
        </svg>
      </div>

      <!-- Title & Desc -->
      <div>
        <h2 class="text-white font-bold text-lg mb-1">Konfirmasi Hapus</h2>
        <p class="text-slate-400 text-sm leading-relaxed">
          Data karyawan ini akan dihapus secara permanen dari database.
        </p>
      </div>

      <!-- Target Name -->
      <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 w-full flex items-center gap-3">
        <div id="deleteAvatar" class="w-9 h-9 rounded-full bg-red-500/20 text-red-400 flex items-center justify-center text-sm font-semibold shrink-0"></div>
        <div class="text-left">
          <p class="text-slate-500 text-xs">Hapus akun</p>
          <p id="deleteName" class="text-white font-medium text-sm"></p>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex gap-3 w-full mt-1">
        <button onclick="closeDeleteModal()"
          class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 text-slate-300 py-2.5 rounded-xl text-sm transition-colors">
          ✕ Batal
        </button>
        <form id="deleteForm" method="POST" class="flex-1">
          <input type="hidden" name="_csrf" id="deleteCsrf" value="" />
          <button type="submit"
            class="w-full bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-xl text-sm font-semibold transition-colors">
            🗑 Hapus
          </button>
        </form>
      </div>

    </div>
  </div>
</main>

<script>
  window.openDeleteModal = function openDeleteModal(button) {
    const action = button.dataset.action;
    const name = button.dataset.name || '';

    document.getElementById('deleteForm').action = action;
    document.getElementById('deleteName').textContent = name;
    document.getElementById('deleteAvatar').textContent = name.substring(0, 2).toUpperCase();
    document.getElementById('deleteCsrf').value = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
    const modal = document.getElementById('deleteModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  window.closeDeleteModal = function closeDeleteModal() {
    const modal = document.getElementById('deleteModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // Tutup modal jika klik area luar
  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
  });
</script>

<%-include('../partials/bottomnav.ejs') %>

<%- include('../partials/footer.ejs') %>
