<%-include('../partials/head.ejs', { title: title }) %>
<%- include('../partials/sidebar.ejs') %>

<main class="md:ml-64 pt-14 md:pt-0 pb-20 md:pb-8 min-h-screen">
  <div class="max-w-6xl mx-auto px-4 py-6 space-y-5">

    <!-- Header -->
    <div class="flex items-center gap-3">
      <a href="/admin/dashboard" class="w-9 h-9 bg-slate-800 border border-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors">←</a>
      <div>
        <h1 class="text-xl font-bold text-white">🛡️ Audit Log Aktivitas Admin</h1>
        <p class="text-sm text-slate-500">Log mutasi sistem bersifat immutable (tidak dapat diubah/dihapus)</p>
      </div>
    </div>

    <!-- Alert Keamanan -->
    <div class="bg-amber-500/5 border border-amber-500/20 rounded-2xl p-4 text-xs text-amber-300">
      ⚠️ <b>Sistem Audit Log Immutable Aktif:</b> Seluruh log tersimpan langsung di database secara permanen untuk kebutuhan forensik data keamanan dan kepatuhan audit sistem absensi.
    </div>

    <!-- Tabel Audit Log -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
      <div class="overflow-x-auto">
        <table class="w-full table-fixed text-sm text-left">
          <colgroup>
            <col style="width: 45px">
            <col style="width: 110px">
            <col style="width: 150px">
            <col style="width: 200px">
            <col style="width: 85px">
            <col style="width: 150px">
            <col style="width: 105px">
          </colgroup>
          <thead>
            <tr class="border-b border-slate-800 text-slate-500 text-xs">
              <th class="px-3 py-4 font-semibold">No</th>
              <th class="px-3 py-4 font-semibold">Nama Admin</th>
              <th class="px-3 py-4 font-semibold">Aksi</th>
              <th class="px-3 py-4 font-semibold">Target Data</th>
              <th class="px-3 py-4 font-semibold">IP</th>
              <th class="px-3 py-4 font-semibold">Browser/Device</th>
              <th class="px-3 py-4 font-semibold">Waktu</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/40">
            <% if (logs && logs.length > 0) { %>
              <% logs.forEach((log, index) => { 
                // Format Target Data jika berupa JSON string
                let formattedTarget = '—';
                let targetTooltip = '';
                if (log.target_data) {
                  try {
                    const parsed = JSON.parse(log.target_data);
                    // Sesuaikan formatting berdasarkan aksi
                    if (log.aksi && log.aksi.includes('Tambah Hari Libur')) {
                      formattedTarget = `Libur: ${parsed.nama_hari_libur} (${parsed.tanggal})`;
                      targetTooltip = `Nama: ${parsed.nama_hari_libur}\nTanggal: ${parsed.tanggal}`;
                    } 
                    else if (log.aksi && log.aksi.includes('Hapus Jadwal Kerja')) {
                      formattedTarget = `Jadwal: ${parsed.name || parsed.role || ''}`;
                      targetTooltip = `Name: ${parsed.name}\nRole: ${parsed.role}`;
                    }
                    else if (log.aksi && log.aksi.includes('Simpan/Update Jadwal')) {
                      formattedTarget = `Jadwal: ${parsed.name} (${parsed.jam_masuk} - ${parsed.jam_pulang})`;
                      targetTooltip = `Name: ${parsed.name}\nRole ID: ${parsed.role_id}\nJam: ${parsed.jam_masuk} → ${parsed.jam_pulang}`;
                    }
                    else if (log.aksi && log.aksi.includes('Ubah Status Absen')) {
                      formattedTarget = `User: ${parsed.user} | ${parsed.old_status} → ${parsed.new_status}`;
                      targetTooltip = `User: ${parsed.user}\nStatus lama: ${parsed.old_status}\nStatus baru: ${parsed.new_status}\nAlasan: ${parsed.reason || '-'}`;
                    }
                    else {
                      // fallback: tampilkan key-value singkat
                      const parts = Object.entries(parsed).map(([k,v]) => `${k}:${v}`).join(', ');
                      formattedTarget = parts.substring(0, 60);
                      targetTooltip = JSON.stringify(parsed, null, 2);
                    }
                  } catch(e) {
                    formattedTarget = log.target_data.substring(0, 60);
                    targetTooltip = log.target_data;
                  }
                }
              %>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="px-3 py-4 text-slate-500 font-mono text-center"><%= index + 1 %></td>
                <td class="px-3 py-4 text-white font-medium truncate" title="<%= log.nama_admin || '' %>">
                  <div class="flex items-center gap-1">
                    <div class="w-5 h-5 shrink-0 rounded-full bg-sky-500/10 text-sky-400 flex items-center justify-center text-[9px] font-bold">
                      <%= (log.nama_admin || 'A').substring(0,2).toUpperCase() %>
                    </div>
                    <span class="truncate"><%= log.nama_admin || '-' %></span>
                  </div>
                </td>
                <td class="px-3 py-4">
                  <span class="inline-block px-2 py-0.5 rounded-lg text-xs font-medium bg-slate-800 text-slate-200 border border-slate-700/50 whitespace-normal break-words" title="<%= log.aksi || '' %>">
                    <%= log.aksi ? log.aksi.substring(0, 50) : '-' %>
                  </span>
                </td>
                <td class="px-3 py-4">
                  <div class="text-xs text-slate-300 truncate max-w-[180px]" title="<%= targetTooltip || formattedTarget %>">
                    <%= formattedTarget %>
                  </div>
                </td>
                <td class="px-3 py-4 text-xs font-mono text-slate-400 truncate"><%= log.ip_address || '—' %></td>
                <td class="px-3 py-4">
                  <div class="text-xs text-slate-400 truncate max-w-[140px]" title="<%= log.user_agent || '' %>">
                    <%= log.user_agent ? log.user_agent.split(' ').slice(0,3).join(' ') + '...' : '—' %>
                  </div>
                </td>
                <td class="px-3 py-4 text-xs font-mono text-slate-500 whitespace-nowrap">
                  <%= log.created_at ? new Date(log.created_at).toLocaleString('id-ID', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit', second:'2-digit' }) : '—' %>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center text-slate-500 py-12">
                  <div class="text-3xl mb-2">🛡️</div>
                  <div class="text-sm">Belum ada rekaman log audit admin</div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <div class="px-5 py-3 text-xs text-slate-600 border-t border-slate-800/60">
        Menampilkan <%= logs ? logs.length : 0 %> log aktivitas admin terakhir
      </div>
    </div>

  </div>
</main>

<%-include('../partials/bottomnav.ejs') %>
<%- include('../partials/footer.ejs') %>