<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .bg-grid {
      background-image: linear-gradient(rgba(14,165,233,.05) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(14,165,233,.05) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    .orb1 { background: radial-gradient(circle, rgba(14,165,233,.3), transparent 70%); }
    .orb2 { background: radial-gradient(circle, rgba(56,189,248,.2), transparent 70%); }
    .shimmer { background: linear-gradient(90deg, transparent, rgba(14,165,233,.6), rgba(56,189,248,.6), transparent); background-size: 200% 100%; animation: shimmer 2.5s linear infinite; }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .slide-up { animation: slideUp .6s cubic-bezier(.22,1,.36,1) both; }
    @keyframes slideUp { from{opacity:0;transform:translateY(40px)scale(.97)} to{opacity:1;transform:translateY(0)scale(1)} }
    input:focus, select:focus { outline: none; }
    .spin { animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body class="bg-slate-950 min-h-screen flex items-center justify-center overflow-hidden">

<!-- Background -->
<div class="fixed inset-0 z-0">
  <div class="absolute inset-0 bg-grid"></div>
  <div class="orb1 absolute w-96 h-96 rounded-full blur-[100px] opacity-40 -top-32 -left-32 animate-pulse"></div>
  <div class="orb2 absolute w-72 h-72 rounded-full blur-[90px] opacity-30 -bottom-20 -right-20 animate-pulse" style="animation-delay:1s"></div>
</div>

<div class="relative z-10 w-full max-w-sm mx-auto px-4 slide-up">
  <div class="bg-slate-900/90 backdrop-blur-2xl border border-slate-800 rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
    <!-- Top shimmer bar -->
    <div class="h-0.5 shimmer"></div>

    <div class="p-8">
      <!-- Header -->
      <div class="flex items-center gap-4 mb-8">
        <div class="w-14 h-14 rounded-2xl bg-sky-500/10 border border-sky-500/30 flex items-center justify-center shadow-inner" aria-hidden="true">
          <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 21h18M5 21V5a2 2 0 012-2h7a2 2 0 012 2v16M9 7h1m-1 4h1m-1 4h1m5-6h1m-1 4h1m-1 4h1M17 21v-5a2 2 0 012-2h0a2 2 0 012 2v5"/>
          </svg>
        </div>
        <div>
          <h1 class="text-xl font-bold text-white">Dashboard Absen</h1>
          <p class="text-xs text-slate-500 mt-0.5">Sistem Absensi Karyawan</p>
        </div>
      </div>

      <!-- Flash messages -->
      <% if (error && error.length) { %>
        <div class="mb-4 flex items-center gap-2 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <div class="flex-1 leading-relaxed"><%= error[0] %></div>
        </div>
      <% } %>
      <% if (success && success.length) { %>
        <div class="mb-4 flex items-center gap-2 bg-green-500/10 border border-green-500/20 text-green-400 text-sm px-4 py-3 rounded-xl">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <div class="flex-1"><%= success[0] %></div>
        </div>
      <% } %>

      <!-- Form -->
      <form action="/login" method="POST" id="loginForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="mb-4">
          <label class="block text-xs font-semibold text-sky-400 uppercase tracking-wider mb-2">Username</label>
          <div class="relative">
            <select name="username" id="username" required autocomplete="username"
              class="w-full bg-slate-800/60 border border-slate-700 text-white rounded-xl px-4 py-3 pr-10 text-sm focus:border-sky-500 focus:bg-slate-800 transition-colors appearance-none">
              <option value="">Pilih username</option>
              <% (loginUsers || []).forEach(u => { %>
                <option value="<%= u.username %>"><%= u.username %> - <%= u.jabatan || 'No Job' %><%= u.role === 'admin' ? ' (Admin)' : u.role === 'superadmin' ? ' (Superadmin)' : '' %></option>
              <% }) %>
            </select>
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </div>
        </div>

        <div class="mb-4">
          <label class="block text-xs font-semibold text-sky-400 uppercase tracking-wider mb-2">Password</label>
          <div class="relative">
            <input type="password" name="password" id="password" required autocomplete="current-password"
              placeholder="Masukkan password Anda"
              class="w-full bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 rounded-xl px-4 py-3 pr-10 text-sm focus:border-sky-500 focus:bg-slate-800 transition-colors">
            <button type="button" onclick="togglePw()" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-600 hover:text-slate-400 transition-colors">
              <svg id="eyeOpen" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <svg id="eyeClose" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            </button>
          </div>
        </div>

        <div class="mb-6 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <input type="checkbox" name="remember_me" id="remember_me" value="1"
              class="w-4 h-4 rounded border-slate-700 bg-slate-800 text-sky-500 focus:ring-sky-500 cursor-pointer">
            <label for="remember_me" class="text-xs text-slate-400 select-none cursor-pointer">Ingat Saya (Remember Me)</label>
          </div>
        </div>

        <button type="submit" id="btnLogin"
          class="w-full py-3.5 bg-sky-500 hover:bg-sky-400 active:bg-sky-600 text-white font-semibold rounded-xl transition-all duration-200 flex items-center justify-center gap-2 text-sm shadow-lg shadow-sky-500/30 hover:shadow-sky-500/50 hover:-translate-y-0.5 cursor-pointer">
          <svg id="btnSpinner" class="w-4 h-4 spin hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          <span id="btnText">Masuk</span>
        </button>
      </form>
    </div>

    <div class="px-8 py-4 border-t border-slate-800 flex items-center justify-between text-xs text-slate-600 font-mono">
      <span>Dashboard Absen v1.2</span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
        Online
      </span>
    </div>
  </div>
</div>

<script>
function togglePw() {
  const pw = document.getElementById('password');
  const show = pw.type === 'password';
  pw.type = show ? 'text' : 'password';
  document.getElementById('eyeOpen').classList.toggle('hidden', show);
  document.getElementById('eyeClose').classList.toggle('hidden', !show);
}

document.getElementById('loginForm').addEventListener('submit', () => {
  const btn = document.getElementById('btnLogin');
  btn.disabled = true;
  document.getElementById('btnSpinner').classList.remove('hidden');
  document.getElementById('btnText').textContent = 'Memproses...';
});
</script>
</body>
</html>
