<%-include('partials/head.ejs', { title: title }) %>
<%- include('partials/sidebar.ejs') %>

<main class="md:ml-64 pt-14 md:pt-0 pb-20 md:pb-8 min-h-screen">
  <div class="max-w-lg mx-auto px-4 py-6 space-y-4">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-2">
      <a href="<%= (user.role === 'admin' || user.role === 'superadmin') ? '/admin/dashboard' : '/dashboard' %>"
         class="w-9 h-9 bg-slate-800 border border-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-lg font-bold text-white"><%= mode === 'checkout' ? '🔴 Check-Out' : '🟢 Check-In' %></h1>
        <p class="text-xs text-slate-500">Absensi <%= mode === 'checkout' ? 'pulang' : 'masuk' %> kerja</p>
      </div>
    </div>

    <!-- Flash -->
    <% if (error && error.length) { %>
      <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl"><%= error[0] %></div>
    <% } %>

    <!-- Time display -->
    <div class="bg-gradient-to-br from-sky-600 to-blue-700 rounded-2xl p-5 text-center shadow-lg shadow-sky-500/20">
      <div class="text-4xl font-bold text-white tracking-tight" id="liveTime">--:--:--</div>
      <div class="text-sky-200 text-sm mt-1" id="liveDate">--</div>
    </div>

    <!-- Form -->
    <% const actionUrl = mode === 'checkout' ? '/attendance/checkout' : '/attendance/checkin'; %>
    <form action="<%= actionUrl %>" method="POST" id="absenForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <% if (mode === 'checkin') { %>
      <!-- Pilih Status -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 mb-3">
        <div class="text-xs text-slate-500 uppercase tracking-wider font-semibold mb-3">Pilih Status Kehadiran</div>
        <div class="grid grid-cols-2 gap-2">
          <% options.forEach((opt, i) => { %>
            <label class="option-radio cursor-pointer">
              <input type="radio" name="option_id" value="<%= opt.id %>" class="sr-only" <%= i === 0 ? 'checked' : '' %>>
              <div class="option-label flex items-center gap-2 p-3 bg-slate-800 border border-slate-700 rounded-xl hover:border-sky-500/50 transition-all text-sm font-medium text-slate-300 hover:text-white" style="--opt-color: <%= opt.color %>">
                <span class="w-3 h-3 rounded-full flex-shrink-0" style="background:<%= opt.color %>"></span>
                <span><%= opt.name %></span>
              </div>
            </label>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Catatan -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 mb-3">
        <label class="text-xs text-slate-500 uppercase tracking-wider font-semibold mb-2 block">Catatan (opsional)</label>
        <textarea name="notes" rows="2" placeholder="Tambahkan catatan jika ada…"
          class="w-full bg-slate-800 border border-slate-700 text-white placeholder-slate-600 rounded-xl px-4 py-3 text-sm focus:border-sky-500 focus:outline-none transition-colors resize-none"></textarea>
      </div>

      <!-- Foto -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 mb-3">
        <div class="text-xs text-slate-500 uppercase tracking-wider font-semibold mb-3">Foto Selfie</div>
        <div id="cameraSection">
          <video id="video" class="w-full rounded-xl object-cover aspect-video bg-black" autoplay playsinline style="transform:scaleX(-1)"></video>
          <div id="cameraStatus" class="mt-2 text-xs text-slate-500">Menyiapkan kamera...</div>
          <div class="flex gap-2 mt-3">
            <button type="button" onclick="capturePhoto()" id="btnCapture" disabled class="flex-1 py-2.5 bg-sky-500 hover:bg-sky-400 disabled:bg-slate-700 disabled:text-slate-400 text-white text-sm font-semibold rounded-xl transition-colors">📸 Ambil Foto</button>
            <button type="button" onclick="startCamera()" id="btnRetake" class="hidden flex-1 py-2.5 bg-slate-700 hover:bg-slate-600 text-white text-sm font-semibold rounded-xl transition-colors">🔄 Ulang</button>
          </div>
        </div>
        <canvas id="canvas" class="hidden w-full rounded-xl"></canvas>
        <img id="photoPreview" class="hidden w-full rounded-xl object-cover aspect-video" alt="Foto">
        <input type="hidden" name="photo_data" id="photoData">
      </div>

      <!-- Lokasi -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 mb-4">
        <div class="text-xs text-slate-500 uppercase tracking-wider font-semibold mb-3">Lokasi</div>
        <button type="button" onclick="getLocation()" id="btnLoc"
          class="w-full py-2.5 bg-slate-800 border border-slate-700 hover:border-sky-500/50 text-slate-300 text-sm font-medium rounded-xl transition-all flex items-center justify-center gap-2">
          <span>📍</span><span id="locLabel">Ambil Lokasi GPS</span>
        </button>
        <div id="locInfo" class="mt-2 text-xs text-slate-500 hidden"></div>
        <input type="hidden" name="location" id="locationInput">
      </div>

      <!-- Submit -->
      <button type="submit" id="btnSubmit"
        class="w-full py-4 <%= mode === 'checkout' ? 'bg-gradient-to-r from-rose-500 to-red-600 shadow-red-500/25' : 'bg-gradient-to-r from-sky-500 to-sky-600 shadow-sky-500/25' %> text-white font-bold text-base rounded-2xl shadow-lg transition-all hover:-translate-y-0.5 hover:shadow-xl flex items-center justify-center gap-2">
        <%= mode === 'checkout' ? '🔴 Konfirmasi Check-Out' : '🟢 Konfirmasi Check-In' %>
      </button>
    </form>
  </div>
</main>

<%-include('partials/bottomnav.ejs') %>

<script>
// Live clock
function tick() {
  const now = new Date();
  const days = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
  const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
  document.getElementById('liveTime').textContent = now.toLocaleTimeString('id-ID');
  document.getElementById('liveDate').textContent = `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
}
tick(); setInterval(tick, 1000);

// Option radio styling
document.querySelectorAll('.option-radio input').forEach(input => {
  function updateStyle() {
    const label = input.nextElementSibling;
    if (input.checked) {
      label.style.borderColor = label.style.getPropertyValue('--opt-color') || '#0ea5e9';
      label.style.backgroundColor = (label.style.getPropertyValue('--opt-color') || '#0ea5e9') + '15';
      label.style.color = '#fff';
    } else {
      label.style.borderColor = '';
      label.style.backgroundColor = '';
      label.style.color = '';
    }
  }
  updateStyle();
  input.addEventListener('change', () => {
    document.querySelectorAll('.option-radio input').forEach(i => i.nextElementSibling.style.borderColor = '');
    updateStyle();
  });
});

// Camera
let cameraStream = null;

function setCameraStatus(message, isError = false) {
  const status = document.getElementById('cameraStatus');
  status.textContent = message;
  status.className = 'mt-2 text-xs ' + (isError ? 'text-red-400' : 'text-slate-500');
}

async function startCamera() {
  const video = document.getElementById('video');
  const btnCapture = document.getElementById('btnCapture');

  btnCapture.disabled = true;
  setCameraStatus('Menyiapkan kamera...');

  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    setCameraStatus('Browser tidak mendukung kamera. Gunakan Chrome/Edge dan akses dari localhost atau HTTPS.', true);
    return;
  }

  try {
    if (cameraStream) {
      cameraStream.getTracks().forEach(track => track.stop());
    }

    const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
    cameraStream = stream;
    video.srcObject = stream;
    await video.play();
    video.classList.remove('hidden');
    document.getElementById('photoPreview').classList.add('hidden');
    document.getElementById('btnRetake').classList.add('hidden');
    document.getElementById('photoData').value = '';
    btnCapture.disabled = false;
    setCameraStatus('Kamera siap.');
  } catch (err) {
    console.error(err);
    setCameraStatus('Kamera tidak bisa dibuka. Izinkan akses kamera, lalu buka halaman dari localhost atau HTTPS.', true);
  }
}
startCamera();

function capturePhoto() {
  const video = document.getElementById('video');
  if (!video.videoWidth || !video.videoHeight) {
    setCameraStatus('Kamera belum siap, coba beberapa detik lagi.', true);
    return;
  }

  const canvas = document.getElementById('canvas');
  canvas.width = video.videoWidth || 640;
  canvas.height = video.videoHeight || 480;
  const ctx = canvas.getContext('2d');
  ctx.scale(-1, 1);
  ctx.drawImage(video, -canvas.width, 0, canvas.width, canvas.height);
  const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
  document.getElementById('photoPreview').src = dataUrl;
  document.getElementById('photoPreview').classList.remove('hidden');
  video.classList.add('hidden');
  document.getElementById('btnRetake').classList.remove('hidden');
  document.getElementById('photoData').value = dataUrl;
  setCameraStatus('Foto berhasil diambil.');

  if (cameraStream) {
    cameraStream.getTracks().forEach(track => track.stop());
    cameraStream = null;
  }
}

// Geolocation
function getLocation() {
  const btn = document.getElementById('btnLoc');
  const label = document.getElementById('locLabel');
  label.textContent = '⏳ Mengambil lokasi…';
  btn.disabled = true;
  navigator.geolocation.getCurrentPosition(pos => {
    const coords = `${pos.coords.latitude.toFixed(6)}, ${pos.coords.longitude.toFixed(6)}`;
    document.getElementById('locationInput').value = coords;
    document.getElementById('locInfo').textContent = '📍 ' + coords;
    document.getElementById('locInfo').classList.remove('hidden');
    label.textContent = '✅ Lokasi berhasil diambil';
    btn.classList.add('border-green-500/50', 'text-green-400');
    btn.disabled = false;
  }, () => {
    label.textContent = '❌ Gagal ambil lokasi';
    btn.disabled = false;
  }, { timeout: 10000 });
}

// Confirm before submit
document.getElementById('absenForm').addEventListener('submit', (e) => {
  const btn = document.getElementById('btnSubmit');
  btn.disabled = true;
  btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Menyimpan…';
});
</script>

<%- include('partials/footer.ejs') %>
