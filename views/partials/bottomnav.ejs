<!-- ✅ MODAL LOGOUT -->
<style>
  #logoutOverlay {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(5,10,28,0.80); backdrop-filter: blur(6px);
    align-items: flex-end; justify-content: center;
    padding-bottom: 80px;
  }
  #logoutOverlay.show { display: flex; }
  .logout-box {
    background: linear-gradient(160deg, #0f1f45 0%, #0d1835 100%);
    border: 1px solid rgba(99,148,255,0.2);
    border-radius: 20px; padding: 2rem 1.75rem 1.75rem;
    width: 92%; max-width: 360px; text-align: center;
    box-shadow: 0 24px 48px rgba(0,0,0,0.6);
    animation: slideUp 0.2s ease;
  }
  @keyframes slideUp {
    from { transform: translateY(30px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  .logout-icon-wrap {
    width: 64px; height: 64px; border-radius: 16px; margin: 0 auto 1.1rem;
    background: linear-gradient(135deg, #1a3a7a, #1e4494);
    border: 1px solid rgba(99,148,255,0.35);
    box-shadow: 0 0 24px rgba(37,99,235,0.3);
    display: flex; align-items: center; justify-content: center;
  }
  .logout-title { font-size: 19px; font-weight: 700; color: #fff; margin-bottom: 6px; }
  .logout-desc  { font-size: 13px; color: rgba(180,200,255,0.65); line-height: 1.6; margin-bottom: 1.25rem; }
  .logout-pill  {
    display: flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(99,148,255,0.18);
    border-radius: 10px; padding: 9px 13px; margin-bottom: 1.25rem; text-align: left;
  }
  .logout-avatar {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, #1a3a7a, #2563eb);
    border: 1px solid rgba(99,148,255,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: #93c5fd;
  }
  .logout-pill small  { font-size: 10px; color: rgba(148,180,255,0.55); display: block; }
  .logout-pill strong { font-size: 13px; color: #e0edff; }
  .logout-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .btn-batal-lo {
    padding: 11px 0; font-size: 14px; font-weight: 600; border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.06);
    color: rgba(200,220,255,0.85); cursor: pointer; transition: background 0.15s;
  }
  .btn-batal-lo:hover { background: rgba(255,255,255,0.12); }
  .btn-logout-lo {
    padding: 11px 0; font-size: 14px; font-weight: 600; border-radius: 10px;
    border: none; background: linear-gradient(135deg, #1d4ed8, #2563eb);
    color: #fff; cursor: pointer; box-shadow: 0 4px 16px rgba(37,99,235,0.4);
    display: flex; align-items: center; justify-content: center; gap: 6px;
    text-decoration: none; transition: filter 0.15s;
  }
  .btn-logout-lo:hover { filter: brightness(1.15); }
</style>

<div id="logoutOverlay" onclick="if(event.target===this)closeLogout()">
  <div class="logout-box">
    <div class="logout-icon-wrap">
      <svg width="28" height="28" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </div>
    <p class="logout-title">Konfirmasi Logout</p>
    <p class="logout-desc">Sesi kamu akan diakhiri dan kamu akan<br>diarahkan ke halaman login.</p>
    <div class="logout-pill">
      <div class="logout-avatar">
        <%= sessionUser ? sessionUser.username.slice(0,2).toUpperCase() : 'US' %>
      </div>
      <div>
        <small>Logout sebagai</small>
        <strong><%= sessionUser ? sessionUser.username : '' %></strong>
      </div>
    </div>
    <div class="logout-actions">
      <button class="btn-batal-lo" onclick="closeLogout()">✕ Batal</button>
      <button type="button" class="btn-logout-lo" onclick="confirmLogout()">
        <svg width="14" height="14" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Logout
      </button>
    </div>
  </div>
</div>


<!-- App JS -->
<script src="/js/app.js"></script>
<script>
  window.showLogout = function showLogout() {
    document.getElementById('logoutOverlay').classList.add('show');
  };
  window.closeLogout = function closeLogout() {
    document.getElementById('logoutOverlay').classList.remove('show');
  };
  window.confirmLogout = function confirmLogout() {
    window.location.href = '/logout';
  };
</script>
