<!-- SIDEBAR (Desktop) -->
<aside class="hidden md:flex flex-col fixed left-0 top-0 h-full w-64 bg-slate-900 border-r border-slate-800 z-40">
  <!-- Logo -->
  <div class="flex items-center gap-3 px-6 py-5 border-b border-slate-800">
    <div class="w-10 h-10 rounded-xl bg-sky-500/10 border border-sky-500/30 flex items-center justify-center text-xl">🏢</div>
    <div>
      <div class="font-bold text-white text-sm">Dashboard Absen</div>
      <div class="text-xs text-slate-500">Sistem Absensi</div>
    </div>
  </div>

  <!-- User Profile -->
  <div class="px-4 py-4 border-b border-slate-800">
    <div class="flex items-center gap-3 p-3 bg-slate-800/50 rounded-xl">
      <div class="relative">
        <% if (sessionUser && sessionUser.photo) { %>
          <img src="/uploads/<%= sessionUser.photo %>" class="w-10 h-10 rounded-full object-cover border-2 border-sky-500/50" alt="Foto">
        <% } else { %>
          <div class="w-10 h-10 rounded-full bg-sky-500/20 border-2 border-sky-500/50 flex items-center justify-center text-sky-400 font-bold text-sm">
           <%= sessionUser ? sessionUser.username.charAt(0).toUpperCase() : '?' %>
          </div>
        <% } %>
        <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 border-2 border-slate-800 rounded-full"></span>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-semibold text-white truncate"><%= sessionUser ? sessionUser.username.split(' ')[0] : '' %></div>
        <div class="text-xs text-slate-400 truncate"><%= sessionUser ? sessionUser.jabatan : '' %></div>
      </div>
      <% if (sessionUser && (sessionUser.role === 'admin' || sessionUser.role === 'superadmin')) { %>
        <span class="text-xs bg-sky-500/20 text-sky-400 border border-sky-500/30 px-1.5 py-0.5 rounded-md font-medium">Admin</span>
      <% } %>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 overflow-y-auto">
    <div class="space-y-1">
      <a href="<%= sessionUser && (sessionUser.role === 'admin' || sessionUser.role === 'superadmin') ? '/admin/dashboard' : '/dashboard' %>" class="nav-item <%= currentPath === '/dashboard' || currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      
      <!-- HAPUS MENU "ABSEN SEKARANG" SESUAI KETENTUAN 6 -->
      
      <a href="/history" class="nav-item <%= currentPath === '/history' ? 'active' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Histori Absensi
      </a>
    </div>

    <% if (sessionUser && (sessionUser.role === 'admin' || sessionUser.role === 'superadmin')) { %>
    <div class="mt-6">
      <div class="text-xs text-slate-600 uppercase tracking-wider px-3 mb-2 font-semibold">Admin Panel</div>
      <div class="space-y-1">
        <a href="/admin/users" class="nav-item <%= currentPath === '/admin/users' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          Kelola Karyawan
        </a>
        <a href="/admin/schedules" class="nav-item <%= currentPath === '/admin/schedules' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Jadwal Jabatan
        </a>
        <a href="/admin/holidays" class="nav-item <%= currentPath === '/admin/holidays' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Hari Libur / Tanggal Merah
        </a>
        <a href="/admin/int-options" class="nav-item <%= currentPath === '/admin/int-options' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Opsi Form Absen
        </a>
        <% if (sessionUser.role === 'superadmin') { %>
        <a href="/admin/activity-history" class="nav-item <%= currentPath === '/admin/activity-history' ? 'active' : '' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Audit Log Admin
        </a>
        <% } %>
      </div>
    </div>
    <% } %>
  </nav>

  <!-- Logout -->
  <div class="p-3 border-t border-slate-800">
    <button onclick="showLogout()" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-red-400 hover:bg-red-500/10 transition-colors duration-200 text-sm font-medium bg-transparent border-0 cursor-pointer">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Logout
    </button>
  </div>
</aside>

<!-- TOPBAR Mobile -->
<header class="md:hidden fixed top-0 left-0 right-0 z-40 bg-slate-900/95 backdrop-blur border-b border-slate-800">
  <div class="flex items-center justify-between px-4 h-14">
    <div class="flex items-center gap-2">
      <span class="text-xl">🏢</span>
      <span class="font-bold text-white text-sm">Dashboard Absen</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-xs text-slate-400"><%= sessionUser ? sessionUser.username.split(' ')[0] : '' %></span>
      <% if (sessionUser && sessionUser.photo) { %>
        <img src="/uploads/<%= sessionUser.photo %>" class="w-8 h-8 rounded-full object-cover border border-sky-500/50" alt="">
      <% } else { %>
        <div class="w-8 h-8 rounded-full bg-sky-500/20 border border-sky-500/50 flex items-center justify-center text-sky-400 font-bold text-xs">
        <%= sessionUser ? sessionUser.username.charAt(0).toUpperCase() : '?' %>
        </div>
      <% } %>
    </div>
  </div>
</header>
